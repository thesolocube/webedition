# ===========================================
# TMDB (serveur uniquement — jamais NEXT_PUBLIC_)
# ===========================================
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3

# ===========================================
# Firebase (client — obligatoire NEXT_PUBLIC_)
# Recuperez ces valeurs dans :
# Firebase Console → Parametres du projet → Vos applications → Web
# ===========================================

# Cle API Web Firebase (ex: AIzaSy...)
NEXT_PUBLIC_FIREBASE_API_KEY=

# Domaine Auth (ex: mon-projet.firebaseapp.com)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=

# ID du projet (ex: mon-projet-12345)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Bucket Storage (ex: mon-projet-12345.firebasestorage.app)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Sender ID (ex: 123456789012)
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# App ID Web (ex: 1:123456789012:web:abcdef123456)
NEXT_PUBLIC_FIREBASE_APP_ID=

# Analytics — optionnel
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ===========================================
# Vercel : ajoutez TOUTES ces variables puis
# redeployez (Settings → Environment Variables)
# ===========================================
